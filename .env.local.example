# Shopify Storefront API — copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Your Shopify store domain (e.g. my-store.myshopify.com)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com

# Public Storefront API token — safe to expose in the browser
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=99a738ba20b53f2183de84f53f4d5bd5

# Storefront API version
NEXT_PUBLIC_SHOPIFY_API_VERSION=2024-10
